    <!-- Wrist camera attached to the end of robot_arm_6_link -->
    <!-- Camera 1: faces arm6 +X (forward) -->
    <link name="wrist_camera_front_link">
      <gravity>false</gravity>
      <pose relative_to="robot_arm_6_link">0.25 0 -0.05 0 0.9599 0</pose>
      <sensor name="wrist_camera_front" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>RGB_INT8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/arm/wrist_camera/image</topic>
      </sensor>
    </link>
    <joint name="wrist_camera_front_fixed" type="fixed">
      <parent>robot_arm_6_link</parent>
      <child>wrist_camera_front_link</child>
    </joint>

    <!-- Camera 2: faces arm6 -Y (user-left), yaw -110° -->
    <link name="wrist_camera_left_link">
      <gravity>false</gravity>
      <pose relative_to="robot_arm_6_link">0.4 0 0 0 0.3142 -1.9199</pose>
      <sensor name="wrist_camera_left" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>RGB_INT8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/arm/wrist_camera_left/image</topic>
      </sensor>
    </link>
    <joint name="wrist_camera_left_fixed" type="fixed">
      <parent>robot_arm_6_link</parent>
      <child>wrist_camera_left_link</child>
    </joint>

    <!-- Camera 3: faces arm6 -X (back), yaw 180° -->
    <link name="wrist_camera_back_link">
      <gravity>false</gravity>
      <pose relative_to="robot_arm_6_link">-1.5 0 0 0 0.2618 3.1415927</pose>
      <sensor name="wrist_camera_back" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>RGB_INT8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/arm/wrist_camera_back/image</topic>
      </sensor>
    </link>
    <joint name="wrist_camera_back_fixed" type="fixed">
      <parent>robot_arm_6_link</parent>
      <child>wrist_camera_back_link</child>
    </joint>

    <!-- Camera 4: faces arm6 +Y (user-right), yaw +100° -->
    <link name="wrist_camera_right_link">
      <gravity>false</gravity>
      <pose relative_to="robot_arm_6_link">0.4 0 0 0 0.0873 1.7453</pose>
      <sensor name="wrist_camera_right" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>RGB_INT8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>/arm/wrist_camera_right/image</topic>
      </sensor>
    </link>
    <joint name="wrist_camera_right_fixed" type="fixed">
      <parent>robot_arm_6_link</parent>
      <child>wrist_camera_right_link</child>
    </joint>

    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
