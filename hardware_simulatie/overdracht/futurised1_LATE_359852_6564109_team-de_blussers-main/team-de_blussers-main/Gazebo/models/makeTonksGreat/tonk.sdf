<?xml version="1.0" ?>
<sdf version="1.10">

  <model name="tonk" canonical_link="base">
    <!-- Spawn height so wheels touch ground: wheel_center = spawn_z + wheel_offset(-0.15) = radius(0.25) → spawn_z = 0.40 -->
    <pose>0 0 0.40 0 0 0</pose>

    <!-- Diff Drive Plugin -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_front_joint</left_joint>
      <left_joint>left_rear_joint</left_joint>
      <right_joint>right_front_joint</right_joint>
      <right_joint>right_rear_joint</right_joint>
      <wheel_separation>1.6</wheel_separation>
      <wheel_radius>0.25</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
    </plugin>

    <!-- Odometry from Wheels Plugin -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>

    <!-- Base Link -->
    <link name="base">
      <inertial>
        <mass>40</mass>
        <inertia><ixx>7.73</ixx><iyy>12.0</iyy><izz>17.33</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>1.8 1.4 0.6</size></box></geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><box><size>1.8 1.4 0.6</size></box></geometry>
      </collision>
    </link>

    <!-- Wheels -->
    <link name="left_front">
      <pose>0.6 0.8 -0.15 -1.57 0 0</pose>
      <inertial><mass>2</mass></inertial>
      <visual name="visual"><geometry><cylinder><radius>0.25</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name="collision">
        <geometry><sphere><radius>0.25</radius></sphere></geometry>
        <surface><friction><ode>
          <mu>1.5</mu><mu2>0.3</mu2><fdir1>1 0 0</fdir1>
        </ode></friction></surface>
      </collision>
    </link>
    <link name="right_front">
      <pose>0.6 -0.8 -0.15 -1.57 0 0</pose>
      <inertial><mass>2</mass></inertial>
      <visual name="visual"><geometry><cylinder><radius>0.25</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name="collision">
        <geometry><sphere><radius>0.25</radius></sphere></geometry>
        <surface><friction><ode>
          <mu>1.5</mu><mu2>0.3</mu2><fdir1>1 0 0</fdir1>
        </ode></friction></surface>
      </collision>
    </link>
    <link name="left_rear">
      <pose>-0.6 0.8 -0.15 -1.57 0 0</pose>
      <inertial><mass>2</mass></inertial>
      <visual name="visual"><geometry><cylinder><radius>0.25</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name="collision">
        <geometry><sphere><radius>0.25</radius></sphere></geometry>
        <surface><friction><ode>
          <mu>1.5</mu><mu2>0.3</mu2><fdir1>1 0 0</fdir1>
        </ode></friction></surface>
      </collision>
    </link>
    <link name="right_rear">
      <pose>-0.6 -0.8 -0.15 -1.57 0 0</pose>
      <inertial><mass>2</mass></inertial>
      <visual name="visual"><geometry><cylinder><radius>0.25</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name="collision">
        <geometry><sphere><radius>0.25</radius></sphere></geometry>
        <surface><friction><ode>
          <mu>1.5</mu><mu2>0.3</mu2><fdir1>1 0 0</fdir1>
        </ode></friction></surface>
      </collision>
    </link>

    <!-- IMU Sensor -->
    <link name="imu">
      <pose>0 0 0.3 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.001</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.001</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.001</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.01</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.01</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.01</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
        <topic>/imu</topic>
      </sensor>
    </link>

    <!-- Pov camera -->
      <!-- link -->
      <link name="camera_link">
        <pose>0.9 0 0.4 0 0 0</pose> <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><box><size>0.1 0.1 0.1</size></box></geometry>
          <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
          </material>
        </visual>
        <!-- sensor -->
        <sensor name="camera" type="camera">
          <pose>0 0 0 0 0 0</pose>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <topic>camera/image_raw</topic>
          <camera>
            <horizontal_fov>1.05</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
        </sensor>
      </link>
      <!-- joint -->
      <joint name="camera_joint" type="fixed">
        <parent>base</parent>
        <child>camera_link</child>
      </joint>


    <!-- LiDAR -->
    <link name="lidar">
      <pose>0 0 0.8 0 0 0</pose>
      <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
        <topic>/lidar</topic>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.2617</min_angle>
              <max_angle>0.2617</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.3</min>
            <max>40.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>
    </link>

    <!-- Feature Thermal Camera -->
    <link name="thermal_camera">
    <pose>0.05 0.05 0.05 0 0 0</pose>
    <collision name="collision">
      <geometry>
        <box>
          <size>0.1 0.1 0.1</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>0.1 0.1 0.1</size>
        </box>
      </geometry>
    </visual>
    <sensor name="thermal_camera_8bit" type="thermal">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>L8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>thermal_camera_8bit/image</topic>
      <plugin
        filename="ignition-gazebo-thermal-sensor-system"
        name="gz::sim::systems::ThermalSensor">
        <min_temp>253.15</min_temp>
        <max_temp>673.15</max_temp>
        <resolution>3.0</resolution>
      </plugin>
    </sensor>
  </link>

    <!-- Thermal camera joint -->
    <joint name="thermal_joint" type="fixed">
      <parent>base</parent>
      <child>thermal_camera</child>
    </joint>

    <!-- Joints: axis expressed in model frame, Y = wheel axle (lateral direction) -->
    <joint name="left_front_joint" type="revolute">
      <parent>base</parent><child>left_front</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit><effort>100</effort><velocity>20</velocity></limit>
        <dynamics><damping>0.05</damping></dynamics>
      </axis>
    </joint>
    <joint name="right_front_joint" type="revolute">
      <parent>base</parent><child>right_front</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit><effort>100</effort><velocity>20</velocity></limit>
        <dynamics><damping>0.05</damping></dynamics>
      </axis>
    </joint>
    <joint name="left_rear_joint" type="revolute">
      <parent>base</parent><child>left_rear</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit><effort>100</effort><velocity>20</velocity></limit>
        <dynamics><damping>0.05</damping></dynamics>
      </axis>
    </joint>
    <joint name="right_rear_joint" type="revolute">
      <parent>base</parent><child>right_rear</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit><effort>100</effort><velocity>20</velocity></limit>
        <dynamics><damping>0.05</damping></dynamics>
      </axis>
    </joint>
    <joint name="imu_joint" type="fixed">
      <parent>base</parent>
      <child>imu</child>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <parent>base</parent>
      <child>lidar</child>
    </joint>

    <!-- ═══════════════════════════════════════════════════════════════════
         BLUSSLANG TURRET
         hose_base  : pan-platform bovenop de robot, draait 360° om Z-as
         hose_nozzle: de slangloop, kantelt 0°–90° om Y-as (horizontaal→recht omhoog)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Pan platform (blauw cilindertje) -->
    <link name="hose_base">
      <pose>0 0 0.42 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.007</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.14</length></cylinder></geometry>
        <material>
          <ambient>0.1 0.1 0.8 1</ambient>
          <diffuse>0.1 0.1 0.8 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.12</radius><length>0.14</length></cylinder></geometry>
      </collision>
    </link>

    <!-- Slangloop / kanon (geel balk, kantelt van horizontaal naar verticaal) -->
    <link name="hose_nozzle">
      <pose>0 0 0.42 0 0 0</pose>
      <inertial>
        <!-- Zwaartepunt op 0.25 m voor de link-origin (midden van het balk) -->
        <pose>0.25 0 0 0 0 0</pose>
        <mass>0.5</mass>
        <inertia><ixx>0.001</ixx><iyy>0.011</iyy><izz>0.011</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <!-- Balk die vooruit wijst (0.5 m lang, 8×8 cm doorsnede) -->
      <visual name="barrel_visual">
        <pose>0.25 0 0 0 0 0</pose>
        <geometry><box><size>0.5 0.08 0.08</size></box></geometry>
        <material>
          <ambient>0.9 0.8 0.0 1</ambient>
          <diffuse>0.9 0.8 0.0 1</diffuse>
        </material>
      </visual>
      <!-- Mondstuk-punt (klein cilindertje aan het uiteinde) -->
      <visual name="tip_visual">
        <pose>0.52 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <pose>0.25 0 0 0 0 0</pose>
        <geometry><box><size>0.5 0.08 0.08</size></box></geometry>
      </collision>
    </link>

    <!-- Pan joint: hose_base draait volledig (360°) om de Z-as -->
    <joint name="hose_pan_joint" type="revolute">
      <parent>base</parent>
      <child>hose_base</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159</lower>
          <upper>3.14159</upper>
          <effort>20</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics><damping>0.4</damping></dynamics>
      </axis>
    </joint>

    <!-- Tilt joint: positieve hoek = omhoog (as geflipt: 0 -1 0 zodat +angle → +Z richting) -->
    <joint name="hose_tilt_joint" type="revolute">
      <parent>hose_base</parent>
      <child>hose_nozzle</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>0.05</lower>
          <upper>1.5708</upper>
          <effort>20</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics><damping>0.4</damping></dynamics>
      </axis>
    </joint>

    <!-- JointPositionController: Pan (ontvangt gz.msgs.Double → std_msgs/Float64 via bridge) -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>hose_pan_joint</joint_name>
      <topic>/hose_pan_cmd</topic>
      <p_gain>3.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <i_max>1.0</i_max>
      <i_min>-1.0</i_min>
    </plugin>

    <!-- JointPositionController: Tilt -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>hose_tilt_joint</joint_name>
      <topic>/hose_tilt_cmd</topic>
      <p_gain>3.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <i_max>1.0</i_max>
      <i_min>-1.0</i_min>
    </plugin>

  </model>
</sdf>