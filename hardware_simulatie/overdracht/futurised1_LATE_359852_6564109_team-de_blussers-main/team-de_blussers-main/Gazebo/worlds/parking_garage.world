      <joint name="body_to_wRR" type="fixed"><parent>body</parent><child>wRR</child></joint>
    </model>

    <!-- CAR B4 - Green, spot B4 -->
    <model name="car_B4">
      <static>true</static>
      <pose>1 -7.5 0 0 0 -1.5708</pose>
