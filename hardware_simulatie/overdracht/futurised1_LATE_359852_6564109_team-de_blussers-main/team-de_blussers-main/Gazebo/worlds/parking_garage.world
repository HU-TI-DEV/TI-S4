      <link name="wFL"><pose>1.1 0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual></link>
      <link name="wFR"><pose>1.1 -0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual></link>
      <link name="wRL"><pose>-1.1 0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual></link>
      <link name="wRR"><pose>-1.1 -0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual></link>
