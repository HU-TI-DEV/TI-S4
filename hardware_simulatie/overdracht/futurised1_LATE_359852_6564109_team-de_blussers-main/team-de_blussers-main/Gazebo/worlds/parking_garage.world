      <joint name="body_to_wRL" type="fixed"><parent>body</parent><child>wRL</child></joint>
      <joint name="body_to_wRR" type="fixed"><parent>body</parent><child>wRR</child></joint>
    </model>

    <!-- ==================== BRANDENDE AUTO - oostelijk einde garage ==================== -->
    <!-- Auto staat in de fik; het doelwit voor de brandweerrobot.
         Positie: x=13.5, y=7.5 - voorbij de laatste parkeerlijn, tegen de oostmuur.
         Rotatie 90° (zelfde richting als rij A).
         Koetswerk is aangekoold/donker, vlammen zijn emissieve geometrie. -->
    <model name="car_A4_burning">
      <static>true</static>
      <pose>13.5 7.5 0 0 0 1.5708</pose>

      <!-- Carrosserie - aangekoold, donkerbruin met oranje gloed -->
      <!-- 673 K = ~400°C: realistisch voor staalplaat in een autobrand -->
      <link name="body">
        <pose>0 0 0.38 0 0 0</pose>
        <collision name="col"><geometry><box><size>4.0 1.75 1.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>4.0 1.75 0.55</size></box></geometry>
          <material><ambient>0.12 0.05 0.01 1</ambient><diffuse>0.18 0.07 0.02 1</diffuse><emissive>0.45 0.12 0.0 1</emissive><specular>0.0 0.0 0.0 1</specular></material>
          <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
            <temperature>673.0</temperature>
          </plugin>
        </visual>
      </link>

      <!-- Dak - zwartgeblakerd, 623 K = ~350°C -->
      <link name="roof">
        <pose>-0.2 0 0.88 0 0 0</pose>
        <visual name="vis">
          <geometry><box><size>2.0 1.5 0.45</size></box></geometry>
          <material><ambient>0.07 0.03 0.01 1</ambient><diffuse>0.1 0.04 0.01 1</diffuse><emissive>0.25 0.07 0.0 1</emissive><specular>0.0 0.0 0.0 1</specular></material>
          <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
            <temperature>623.0</temperature>
          </plugin>
        </visual>
      </link>

      <!-- Wielen - verbrand rubber, 473 K = ~200°C -->
      <link name="wFL"><pose>1.1 0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.04 0.04 0.04 1</ambient><diffuse>0.06 0.06 0.06 1</diffuse></material><plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal"><temperature>473.0</temperature></plugin></visual></link>
      <link name="wFR"><pose>1.1 -0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.04 0.04 0.04 1</ambient><diffuse>0.06 0.06 0.06 1</diffuse></material><plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal"><temperature>473.0</temperature></plugin></visual></link>
      <link name="wRL"><pose>-1.1 0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.04 0.04 0.04 1</ambient><diffuse>0.06 0.06 0.06 1</diffuse></material><plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal"><temperature>473.0</temperature></plugin></visual></link>
      <link name="wRR"><pose>-1.1 -0.88 0.28 1.5708 0 0</pose><visual name="vis"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.04 0.04 0.04 1</ambient><diffuse>0.06 0.06 0.06 1</diffuse></material><plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal"><temperature>473.0</temperature></plugin></visual></link>

      <!-- Vlam laag 1 - brede oranje basis, 973 K = ~700°C -->
      <link name="flame_base">
        <pose>0 0 1.2 0 0 0</pose>
        <visual name="vis">
          <geometry><box><size>2.2 1.3 0.55</size></box></geometry>
          <material><ambient>1.0 0.32 0.0 1</ambient><diffuse>1.0 0.32 0.0 1</diffuse><emissive>1.0 0.22 0.0 1</emissive></material>
          <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
            <temperature>973.0</temperature>
          </plugin>
        </visual>
      </link>

      <!-- Vlam laag 2 - geel-oranje kern, 1173 K = ~900°C -->
      <link name="flame_mid">
        <pose>0.15 0 1.65 0 0 0</pose>
        <visual name="vis">
          <geometry><box><size>1.5 0.85 0.55</size></box></geometry>
          <material><ambient>1.0 0.58 0.02 1</ambient><diffuse>1.0 0.58 0.02 1</diffuse><emissive>1.0 0.45 0.0 1</emissive></material>
          <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
            <temperature>1173.0</temperature>
          </plugin>
        </visual>
      </link>

      <!-- Vlam laag 3 - heetste punt, 1373 K = ~1100°C -->
      <link name="flame_top">
        <pose>-0.05 0 2.05 0 0 0</pose>
        <visual name="vis">
          <geometry><box><size>0.85 0.48 0.5</size></box></geometry>
          <material><ambient>1.0 0.88 0.1 1</ambient><diffuse>1.0 0.88 0.1 1</diffuse><emissive>1.0 0.78 0.05 1</emissive></material>
          <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
            <temperature>1373.0</temperature>
          </plugin>
        </visual>
      </link>

      <!-- Rook, 423 K = ~150°C -->
      <link name="smoke">
        <pose>0.1 0 2.55 0 0 0</pose>
        <visual name="vis">
          <geometry><box><size>2.4 1.4 0.35</size></box></geometry>
          <material><ambient>0.13 0.11 0.09 1</ambient><diffuse>0.16 0.13 0.1 1</diffuse><emissive>0.06 0.05 0.04 1</emissive></material>
          <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
            <temperature>423.0</temperature>
          </plugin>
        </visual>
      </link>

      <!-- Verbindingen (vereist door Gazebo voor multi-link models) -->
      <joint name="j_roof"        type="fixed"><parent>body</parent><child>roof</child></joint>
      <joint name="j_wFL"         type="fixed"><parent>body</parent><child>wFL</child></joint>
      <joint name="j_wFR"         type="fixed"><parent>body</parent><child>wFR</child></joint>
      <joint name="j_wRL"         type="fixed"><parent>body</parent><child>wRL</child></joint>
      <joint name="j_wRR"         type="fixed"><parent>body</parent><child>wRR</child></joint>
      <joint name="j_flame_base"  type="fixed"><parent>body</parent><child>flame_base</child></joint>
      <joint name="j_flame_mid"   type="fixed"><parent>body</parent><child>flame_mid</child></joint>
      <joint name="j_flame_top"   type="fixed"><parent>body</parent><child>flame_top</child></joint>
      <joint name="j_smoke"       type="fixed"><parent>body</parent><child>smoke</child></joint>
    </model>

 <!-- ==================== OBSTAKEL IN DE RIJSTROOK ==================== -->
    <!-- Één betonnen blok midden in de rijstrook; robot moet eromheen. -->
    <model name="obstakel"><static>true</static><pose>0 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><cylinder><radius>0.28</radius><length>0.9</length></cylinder></geometry></collision>
        <visual name="vis"><pose>0 0 0.45 0 0 0</pose><geometry><cylinder><radius>0.28</radius><length>0.9</length></cylinder></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse><specular>0.1 0.1 0.1 1</specular></material></visual>
      </link></model>

    <!-- Afvalbak 2 — onderste rijstrook, wat verder -->
    <model name="afvalbak_2"><static>true</static><pose>3 -4.5 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><cylinder><radius>0.28</radius><length>0.9</length></cylinder></geometry></collision>
        <visual name="vis"><pose>0 0 0.45 0 0 0</pose><geometry><cylinder><radius>0.28</radius><length>0.9</length></cylinder></geometry>
          <material><ambient>0.18 0.18 0.18 1</ambient><diffuse>0.22 0.22 0.22 1</diffuse><specular>0.1 0.1 0.1 1</specular></material></visual>
      </link></model>

    <!-- Pallet (plat) — noordkant, met dozen erop -->
    <model name="pallet"><static>true</static><pose>-10 2.8 0.07 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>1.2 0.8 0.14</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>1.2 0.8 0.14</size></box></geometry>
          <material><ambient>0.45 0.3 0.15 1</ambient><diffuse>0.5 0.33 0.18 1</diffuse></material></visual>
      </link></model>

    <model name="dozen"><static>true</static><pose>-10 2.8 0.55 0 0 0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.9 0.6 0.7</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.9 0.6 0.7</size></box></geometry>
          <material><ambient>0.7 0.6 0.35 1</ambient><diffuse>0.75 0.65 0.4 1</diffuse></material></visual>
      </link></model>

    
      
    <!-- ==================== STANDING PERSON ==================== -->
      <include>
        <uri>file:///../models/person_standing</uri>
        <name>person_standing</name>
        <pose>2 2 0 0 0 4</pose>
    </include>

    <!-- ==================== SPAWN TONK ==================== -->
    <include>
      <uri>file:///../models/makeTonksGreat</uri>
      <name>tonk</name>
      <pose>-14 0 0.50 0 0 0</pose>
    </include>

  </world>
</sdf>