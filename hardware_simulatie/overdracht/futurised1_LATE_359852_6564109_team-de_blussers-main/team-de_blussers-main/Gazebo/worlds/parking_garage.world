        <pose>0 0 0.38 0 0 0</pose>
        <collision name="col"><geometry><box><size>4.0 1.75 1.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>4.0 1.75 0.55</size></box></geometry>
