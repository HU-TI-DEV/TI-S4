<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="room">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>


    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Include FLIP here when needed -->
    
    <model name='FLIP' canonical_link='chassis'>
      <pose>0 0 0 0 0 0</pose>

      <link name='chassis'>
        <pose relative_to='__model__'>0 0 0.625 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>450.0</mass>
          <inertia>
            <ixx>62.438</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>131.438</iyy>
            <iyz>0</iyz>
            <izz>111.188</izz>
          </inertia>
        </inertial>
        <visual name='visual'>
          <geometry><box><size>1.55 0.75 1.05</size></box></geometry>
          <material>
            <ambient>0.0 0.0 1.0 1</ambient>
            <diffuse>0.0 0.0 1.0 1</diffuse>
            <specular>0.0 0.0 1.0 1</specular>
          </material>
        </visual>
        <collision name='collision'>
          <geometry><box><size>1.55 0.75 1.05</size></box></geometry>
        </collision>
        <sensor name="imu_sensor" type="imu">
          <always_on>1</always_on>
          <update_rate>20</update_rate>
          <visualize>true</visualize>
          <topic>imu</topic>
        </sensor>
        <sensor name="gpu_lidar" type="gpu_lidar">
          <pose>0.6 0 0.3 0 0 0</pose>
          <always_on>1</always_on>
          <update_rate>10</update_rate>
          <lidar>
            <scan>
              <horizontal>
                <samples>320</samples>
                <resolution>1</resolution>
                <min_angle>-3.14</min_angle>
                <max_angle>3.14</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.08</min>
              <max>10.0</max>
              <resolution>0.01</resolution>
            </range>
          </lidar>
          <visualize>true</visualize>
          <topic>lidar</topic>
        </sensor>
      </link>


      <link name='left_back_wheel'>
        <pose relative_to="chassis">-0.533 0.475 -0.383 -1.5707 0 0</pose>
        <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
        <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
        <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
      </link>

      <link name='left_middle_wheel'>
        <pose relative_to="chassis">0 0.475 -0.383 -1.5707 0 0</pose>
        <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
        <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
        <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
      </link>

      <link name='right_back_wheel'>
        <pose relative_to="chassis">-0.533 -0.475 -0.383 -1.5707 0 0</pose>
        <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
        <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
        <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
      </link>

      <link name='right_middle_wheel'>
        <pose relative_to="chassis">0 -0.475 -0.383 -1.5707 0 0</pose>
        <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
        <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
        <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
      </link>

      <link name='left_front_steer_link'>
        <pose relative_to="chassis">0.533 0.475 -0.383 0 0 0</pose>
        <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz></inertia></inertial>
      </link>

      <link name='right_front_steer_link'>
        <pose relative_to="chassis">0.533 -0.475 -0.383 0 0 0</pose>
        <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz></inertia></inertial>
      </link>

      <link name='left_front_wheel'>
        <pose relative_to="left_front_steer_link">0 0 0 -1.5707 0 0</pose>
        <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
        <visual name='visual'>
          <geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry>
          <!-- <material><ambient>1.0 0.0 0.0 1</ambient><diffuse>1.0 0.0 0.0 1</diffuse><specular>1.0 0.0 0.0 1</specular></material> -->
        </visual>
        <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
      </link>

      <link name='right_front_wheel'>
        <pose relative_to="right_front_steer_link">0 0 0 -1.5707 0 0</pose>
        <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
        <visual name='visual'>
          <geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry>
          <!-- <material><ambient>1.0 0.0 0.0 1</ambient><diffuse>1.0 0.0 0.0 1</diffuse><specular>1.0 0.0 0.0 1</specular></material> -->
        </visual>
        <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
      </link>



      <!-- Wheel joints -->
      <joint name="left_front_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_front_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="left_middle_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_middle_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="left_back_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_back_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="right_front_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_front_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="right_middle_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_middle_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="right_back_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_back_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
      </joint>


      <!-- Diff Drive Plugin -->
      <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">

      <!-- all 6 wheels driven -->
      <left_joint>left_back_wheel_joint</left_joint>
      <left_joint>left_middle_wheel_joint</left_joint>
      <left_joint>left_front_wheel_joint</left_joint>

      <right_joint>right_back_wheel_joint</right_joint>
      <right_joint>right_middle_wheel_joint</right_joint>
      <right_joint>right_front_wheel_joint</right_joint>

      <wheel_separation>0.95</wheel_separation>
      <wheel_radius>0.242</wheel_radius>

      <topic>/model/FLIP/cmd_vel</topic>
      <odom_topic>/model/FLIP/odometry</odom_topic>
      <tf_topic>/model/FLIP/tf</tf_topic>

      <frame_id>odom</frame_id>
      <child_frame_id>chassis</child_frame_id>

      </plugin>
    </model>
   


    <!-- Walls -->
    <include>
      <uri>file:///workspace/models/obstakels/walls/horizontalWall8_4x0_6x3_5.sdf</uri>
      <name>frontWall</name>
      <pose>4.2 0 1.75 0 0 0</pose>
    </include>


    <include>
      <uri>file:///workspace/models/obstakels/walls/horizontalWall8_4x0_6x3_5.sdf</uri>
      <name>backWall</name>
      <pose>-4.2 0 1.75 0 0 0</pose>
    </include>


    <include>
      <uri>file:///workspace/models/obstakels/walls/verticalWall0_6x8_1x3_5.sdf</uri>
      <name>leftWall</name>
      <pose>0 -3.9 1.75 0 0 1.5708</pose>
    </include>

    <include>
      <uri>file:///workspace/models/obstakels/walls/verticalWall0_6x8_1x3_5.sdf</uri>
      <name>rightWall</name>
      <pose>0 3.9 1.75 0 0 1.5708</pose>
    </include>


    <!-- Objects -->
    <include>
      <uri>file:///workspace/models/obstakels/shapes/redCube1x1x1.sdf</uri>
      <name>redCube</name>
      <pose>3 2 0.5 0 0 0</pose>
    </include>

    <include>
      <uri>file:///workspace/models/obstakels/shapes/greenCylinder0_5x1.sdf</uri>
      <name>greenCylinder</name>
      <pose>-2 -3 0.5 0 0 0</pose>
    </include>


    <include>
      <uri>file:///workspace/models/obstakels/shapes/blueBox1x2x1.sdf</uri>
      <name>blueBox</name>
      <pose>3 -2 0.5 0 0 0</pose>
    </include>

    <include>
      <uri>file:///workspace/models/obstakels/shapes/yellowBox1_5x1x1_5.sdf</uri>
      <name>yellowBox</name>
      <pose>-3 2 0.75 0 0 0</pose>
    </include>


    <include>
      <uri>file:///workspace/models/obstakels/shapes/pinkBall0_6.sdf</uri>
      <name>pinkBall</name>
      <pose>1 3 0.6 0 0 0</pose>
    </include>

    <include>
      <uri>file:///workspace/models/obstakels/shapes/orangeBox0_8x0_8x0_8.sdf</uri>
      <name>orangeBox</name>
      <pose>-2 0 0.4 0 0 0</pose>
    </include>
    
  </world>
</sdf>