<?xml version="1.0" ?>
<sdf version="1.10">
  <model name='FLIP' canonical_link='chassis'>
    <pose>0 0 0 0 0 0</pose>

    <link name='chassis'>
      <pose relative_to='__model__'>0 0 0.625 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>450.0</mass>
        <inertia>
          <ixx>62.438</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>131.438</iyy>
          <iyz>0</iyz>
          <izz>111.188</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <geometry><box><size>1.55 0.75 1.05</size></box></geometry>
        <material>
          <ambient>0.0 0.0 1.0 1</ambient>
          <diffuse>0.0 0.0 1.0 1</diffuse>
          <specular>0.0 0.0 1.0 1</specular>
        </material>
      </visual>
      <collision name='collision'>
        <geometry><box><size>1.55 0.75 1.05</size></box></geometry>
      </collision>
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <visualize>true</visualize>
        <topic>imu</topic>
      </sensor>
      <sensor name="gpu_lidar" type="gpu_lidar">
        <pose>0.6 0 0.3 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>640</samples>
              <resolution>1</resolution>
              <min_angle>-1.396263</min_angle>
              <max_angle>1.396263</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.08</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
        <visualize>true</visualize>
        <topic>lidar</topic>
      </sensor>
    </link>

    <include>
      <uri>file:///workspace/prototypes/camera/camera.sdf</uri>
      <name>camera</name>
      <pose relative_to="chassis">
        0 0 2.05 0 0.3 0
      </pose>
    </include>

		<link name='block'>
			<pose relative_to='chassis'>
				4.0 3.0 2.0 0 0 0
			</pose>
			<inertial>
				<!--inertial properties of the link mass, inertia matix-->
				<mass>5</mass>
				<inertia>
					<ixx>0.095329</ixx>
					<ixy>0</ixy>
					<ixz>0</ixz>
					<iyy>0.381317</iyy>
					<iyz>0</iyz>
					<izz>0.476646</izz>
				</inertia>
			</inertial>
			<visual name='visual'>
				<geometry>
					<box>
						<size>2.0 1.0 0.5</size>
					</box>
				</geometry>
			</visual>
			<collision name='collision'>
				<geometry>
					<box>
						<size>2.0 1.0 0.5</size>
					</box>
				</geometry>
			</collision>
		</link>

    <link name='left_back_wheel'>
      <pose relative_to="chassis">
        -0.533 0.475 -0.383 -1.5707 0 0
      </pose>
      <inertial>
        <mass>5</mass>
        <inertia>
          <ixx>0.694</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1.460</iyy>
          <iyz>0</iyz>
          <izz>1.235</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <geometry>
          <cylinder>
            <radius>0.242</radius>
            <length>0.2</length>
          </cylinder>
        </geometry>
      </visual>
      <collision name='collision'>
        <geometry>
          <cylinder>
            <radius>0.242</radius>
            <length>0.2</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <link name='left_middle_wheel'>
      <pose relative_to="chassis">0 0.475 -0.383 -1.5707 0 0</pose>
      <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
    </link>

    <link name='right_back_wheel'>
      <pose relative_to="chassis">-0.533 -0.475 -0.383 -1.5707 0 0</pose>
      <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
    </link>

    <link name='right_middle_wheel'>
      <pose relative_to="chassis">0 -0.475 -0.383 -1.5707 0 0</pose>
      <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></visual>
      <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
    </link>

    <link name='left_front_steer_link'>
      <pose relative_to="chassis">0.533 0.475 -0.383 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz></inertia></inertial>
    </link>

    <link name='right_front_steer_link'>
      <pose relative_to="chassis">0.533 -0.475 -0.383 0 0 0</pose>
      <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz></inertia></inertial>
    </link>

    <link name='left_front_wheel'>
      <pose relative_to="left_front_steer_link">0 0 0 -1.5707 0 0</pose>
      <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>1.0 0.0 0.0 1</ambient><diffuse>1.0 0.0 0.0 1</diffuse><specular>1.0 0.0 0.0 1</specular></material>
      </visual>
      <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
    </link>

    <link name='right_front_wheel'>
      <pose relative_to="right_front_steer_link">0 0 0 -1.5707 0 0</pose>
      <inertial><mass>5</mass><inertia><ixx>0.694</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.460</iyy><iyz>0</iyz><izz>1.235</izz></inertia></inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>1.0 0.0 0.0 1</ambient><diffuse>1.0 0.0 0.0 1</diffuse><specular>1.0 0.0 0.0 1</specular></material>
      </visual>
      <collision name='collision'><geometry><cylinder><radius>0.242</radius><length>0.2</length></cylinder></geometry></collision>
    </link>

    <joint name='left_back_wheel_joint' type='revolute'>
      <parent>chassis</parent><child>left_back_wheel</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name='left_middle_wheel_joint' type='revolute'>
      <parent>chassis</parent><child>left_middle_wheel</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name='right_back_wheel_joint' type='revolute'>
      <parent>chassis</parent><child>right_back_wheel</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name='right_middle_wheel_joint' type='revolute'>
      <parent>chassis</parent><child>right_middle_wheel</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name='left_front_steering_joint' type='revolute'>
      <parent>chassis</parent><child>left_front_steer_link</child>
      <axis><xyz expressed_in='__model__'>0 0 1</xyz><limit><lower>-1.0</lower><upper>1.0</upper><effort>1000000</effort></limit></axis>
    </joint>
    <joint name='right_front_steering_joint' type='revolute'>
      <parent>chassis</parent><child>right_front_steer_link</child>
      <axis><xyz expressed_in='__model__'>0 0 1</xyz><limit><lower>-1.0</lower><upper>1.0</upper><effort>1000000</effort></limit></axis>
    </joint>
    <joint name='left_front_wheel_joint' type='revolute'>
      <parent>left_front_steer_link</parent><child>left_front_wheel</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name='right_front_wheel_joint' type='revolute'>
      <parent>right_front_steer_link</parent><child>right_front_wheel</child>
      <axis><xyz expressed_in='__model__'>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>

    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_joint>left_back_wheel_joint</left_joint>
      <left_joint>left_middle_wheel_joint</left_joint>
      <left_joint>left_front_wheel_joint</left_joint>
      <right_joint>right_back_wheel_joint</right_joint>
      <right_joint>right_middle_wheel_joint</right_joint>
      <right_joint>right_front_wheel_joint</right_joint>
      <left_steering_joint>left_front_steering_joint</left_steering_joint>
      <right_steering_joint>right_front_steering_joint</right_steering_joint>
      <wheel_base>1.066</wheel_base>
      <wheel_separation>0.95</wheel_separation>
      <kingpin_width>0.95</kingpin_width>
      <wheel_radius>0.242</wheel_radius>
      <steering_limit>1.2</steering_limit>
      <topic>/model/FLIP/cmd_vel</topic>
      <odom_topic>/model/FLIP/odometry</odom_topic>
      <tf_topic>/model/FLIP/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>10</odom_publish_frequency>

      <!-- Uncomment for smoother motion -->
      <!-- <min_velocity>-0.8</min_velocity>
      <max_velocity>0.8</max_velocity>
      <min_acceleration>-0.4</min_acceleration>
      <max_acceleration>0.4</max_acceleration>
      <min_jerk>-1.0</min_jerk>
      <max_jerk>1.0</max_jerk> -->
    </plugin>
  </model>
</sdf>
