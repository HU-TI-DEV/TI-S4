<?xml version="1.0" ?>
<sdf version="1.8">
        <model name='Flip' canonical_link='chassis'>
            <pose>0 0 0 0 0 0</pose>   <!--the pose is relative to the world by default--> 

            <!--Toegevoegd voor het rijden.-->
            <plugin
                filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">

                <left_joint>firstLeftWheelJoint</left_joint>
                <left_joint>secondLeftWheelJoint</left_joint>
                <left_joint>thirdLeftWheelJoint</left_joint>
                <left_joint>fourthLeftWheelJoint</left_joint>

                <right_joint>firstRightWheelJoint</right_joint>
                <right_joint>secondRightWheelJoint</right_joint>
                <right_joint>thirdRightWheelJoint</right_joint>
                <right_joint>fourthRightWheelJoint</right_joint>

                <wheel_separation>1.7</wheel_separation>
                <wheel_radius>0.4</wheel_radius>
                <odom_publish_frequency>1</odom_publish_frequency>
                <topic>cmd_vel</topic>
            </plugin>

            <!--Chassis-->
            <link name='chassis'>
                <pose relative_to='__model__'>0.5 0 0.4 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>1.14395</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <box>
                            <size>1.55 0.75 1.05</size> <!--Length, width, height-->
                        </box>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient> 0.4 0.08 0.08 1.0</ambient>
                        <diffuse> 0.59 0.13 0.12 1.0</diffuse>
                        <specular>0.1 0.1 0.1 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <box>
                            <size>1.55 0.75 1.05</size>
                        </box>
                    </geometry>
                </collision>
            </link>

        <link name='front_block'>
        <pose relative_to='chassis'>0.50 0 0.70 0 0 0</pose>
        <inertial>
            <mass>0.3</mass>
            <inertia>
                <ixx>0.01</ixx>
                <ixy>0</ixy>
                <ixz>0</ixz>
                <iyy>0.01</iyy>
                <iyz>0</iyz>
                <izz>0.01</izz>
            </inertia>
        </inertial>

        <visual name='visual'>
            <geometry>
                <box>
                    <size>0.35 0.35 0.35</size>
                </box>
            </geometry>
            <material>
                <ambient> 0.4 0.08 0.08 1.0</ambient>
                <diffuse> 0.59 0.13 0.12 1.0</diffuse>
                <specular>0.1 0.1 0.1 1.0</specular>
            </material>
        </visual>

            <collision name='collision'>
                <geometry>
                    <box>
                        <size>0.5 0.5 0.5</size>
                    </box>
                </geometry>
            </collision>

    <sensor name='gpu_lidar' type='gpu_lidar'>
        <pose relative_to='lidar_frame'>0 0 0 0 0 0</pose>
        <topic>lidar</topic>
        <update_rate>10</update_rate>
                    <ray>
                        <scan>
                            <horizontal>
                                <samples>1000</samples>
                                <resolution>1</resolution>
                                <min_angle>-3.14159</min_angle>
                                <max_angle>3.14159</max_angle>
                            </horizontal>
                            <vertical>
                                <samples>1</samples>
                                <resolution>0.01</resolution>
                                <min_angle>0</min_angle>
                                <max_angle>0</max_angle>
                            </vertical>
                        </scan>
                        <range>
                            <min>0.08</min>
                            <max>10.0</max>
                            <resolution>0.01</resolution>
                        </range>
                    </ray>
                    <always_on>1</always_on>
                    <visualize>true</visualize>
                </sensor>

        <sensor name="camera" type="camera">
        <pose>0.175 0 -0.10 0 0 0</pose>
        <topic>camera</topic>
        <update_rate>30</update_rate>
        <camera>
            <!-- Veranderd van 1.047 (60 graden) naar 1.5708 (90 graden) -->
            <horizontal_fov>1.5708</horizontal_fov> 
            <image>
                <width>640</width>
                <height>480</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.1</near>
                <far>100</far>
            </clip>
        </camera>
        <always_on>1</always_on>
        <visualize>true</visualize>
        </sensor>

            </link>
      

            <!-- Vast koppelen -->
            <joint name='front_block_fixed_joint' type='fixed'>
                <parent>chassis</parent>
                <child>front_block</child>
            </joint>
            
            <!--First left wheel-->
            <link name='firstLeftWheel'>
                <pose relative_to="chassis">0.5 0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--Left wheel-->
            <link name='secondLeftWheel'>
                <pose relative_to="chassis">0.15 0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <link name='thirdLeftWheel'>
                <pose relative_to="chassis">-0.15 0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <link name='fourthLeftWheel'>
                <pose relative_to="chassis">-0.5 0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--The same as left wheels but with different position-->
            <link name='firstRightWheel'>
                <pose relative_to="chassis">0.5 -0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <link name='secondRightWheel'>
                <pose relative_to="chassis">0.15 -0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <link name='thirdRightWheel'>
                <pose relative_to="chassis">-0.15 -0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <link name='fourthRightWheel'>
                <pose relative_to="chassis">-0.5 -0.45 -0.25 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient> 0.1 0.1 0.1 0.98</ambient>
                        <diffuse> 0.1 0.1 0.1 0.98</diffuse>
                        <specular>0.2 0.2 0.2 1.0</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.3</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--Left wheel joints-->
            <joint name='firstLeftWheelJoint' type='revolute'>
                <pose relative_to='firstLeftWheel'/>
                <parent>chassis</parent>
                <child>firstLeftWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!--can be descired to any frame or even arbitrary frames-->
                    <limit>
                        <lower>-1.79769e+308</lower>    <!--negative infinity-->
                        <upper>1.79769e+308</upper>     <!--positive infinity-->
                    </limit>
                </axis>
            </joint>

            <joint name='secondLeftWheelJoint' type='revolute'>
                <pose relative_to='secondLeftWheel'/>
                <parent>chassis</parent>
                <child>secondLeftWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!--can be descired to any frame or even arbitrary frames-->
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>

            <joint name='thirdLeftWheelJoint' type='revolute'>
                <pose relative_to='thirdLeftWheel'/>
                <parent>chassis</parent>
                <child>thirdLeftWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!--can be descired to any frame or even arbitrary frames-->
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>

            <joint name='fourthLeftWheelJoint' type='revolute'>
                <pose relative_to='fourthLeftWheel'/>
                <parent>chassis</parent>
                <child>fourthLeftWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!--can be descired to any frame or even arbitrary frames-->
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>

            <!--Right wheel joints-->
            <joint name='firstRightWheelJoint' type='revolute'>
                <pose relative_to='firstRightWheel'/>
                <parent>chassis</parent>
                <child>firstRightWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>    <!--negative infinity-->
                        <upper>1.79769e+308</upper>     <!--positive infinity-->
                    </limit>
                </axis>
            </joint>

            <joint name='secondRightWheelJoint' type='revolute'>
                <pose relative_to='secondRightWheel'/>
                <parent>chassis</parent>
                <child>secondRightWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>

            <joint name='thirdRightWheelJoint' type='revolute'>
                <pose relative_to='thirdRightWheel'/>
                <parent>chassis</parent>
                <child>thirdRightWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>

            <joint name='fourthRightWheelJoint' type='revolute'>
                <pose relative_to='fourthRightWheel'/>
                <parent>chassis</parent>
                <child>fourthRightWheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>

        </model>
</sdf>