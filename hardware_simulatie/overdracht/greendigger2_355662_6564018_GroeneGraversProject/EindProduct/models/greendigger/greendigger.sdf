<?xml version='1.0'?>
<sdf version='1.7'>
  <model name='greendigger_complete'>
    <static>false</static>
    <link name='base_link'>
      <pose>0 0 0.38 0 0 0</pose> 
      <inertial>
        <mass>500.0</mass>
        <inertia><ixx>50.0</ixx><ixy>0</ixy><ixz>0</ixz><iyy>50.0</iyy><iyz>0</iyz><izz>50.0</izz></inertia>
      </inertial>
      <visual name='chassis_visual'>
        <geometry><box><size>4.5 2.0 0.3</size></box></geometry>
        <material><ambient>0.0 0.35 0.0 1</ambient><diffuse>0.0 0.4 0.0 1</diffuse></material>
      </visual>
      <visual name='side_pivot_extension_base'>
        <pose>0 1.2 -0.05 0 0 0</pose> 
        <geometry><box><size>1.2 0.4 0.4</size></box></geometry>
        <material><ambient>0.0 0.0 0.0 1</ambient><diffuse>0.0 0.0 0.0 1</diffuse></material>
      </visual>

      <visual name='side_pivot_extension_round'>
        <pose>0 1.4 -0.05 0 0 0</pose> 
        <geometry><cylinder><radius>0.6</radius><length>0.4</length></cylinder></geometry>
        <material><ambient>0.0 0.0 0.0 1</ambient><diffuse>0.0 0.0 0.0 1</diffuse></material>
      </visual>
      <collision name='chassis_collision'>
        <geometry><box><size>4.5 2.0 0.3</size></box></geometry>
      </collision>
    </link>

    <link name='ballast_link'>
      <pose>0 -1.3 0.55 0 0 0</pose>
      <inertial>
        <mass>200.0</mass>
        <inertia><ixx>20.0</ixx><ixy>0</ixy><ixz>0</ixz><iyy>20.0</iyy><iyz>0</iyz><izz>20.0</izz></inertia>
      </inertial>
      <visual name='ballast_visual'>
        <geometry><box><size>1.5 0.6 0.6</size></box></geometry>
        <material><ambient>0.0 0.0 0.0 1</ambient></material>
      </visual>
      <collision name='ballast_collision'>
        <geometry><box><size>1.5 0.6 0.6</size></box></geometry>
      </collision>
    </link>

    <joint name='ballast_joint' type='fixed'>
      <parent>base_link</parent>
      <child>ballast_link</child>
    </joint>

    <link name='wheel_fl'>
      <pose>1.8 1.1 0.4 1.5708 0 0</pose>
      <inertial><mass>2.0</mass><inertia><ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.2</iyy><iyz>0</iyz><izz>0.2</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name='wheel_fr'>
      <pose>1.8 -1.1 0.4 1.5708 0 0</pose>
      <inertial><mass>2.0</mass><inertia><ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.2</iyy><iyz>0</iyz><izz>0.2</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name='wheel_rl'>
      <pose>-1.8 1.1 0.4 1.5708 0 0</pose>
      <inertial><mass>2.0</mass><inertia><ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.2</iyy><iyz>0</iyz><izz>0.2</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name='wheel_rr'>
      <pose>-1.8 -1.1 0.4 1.5708 0 0</pose>
      <inertial><mass>2.0</mass><inertia><ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.2</iyy><iyz>0</iyz><izz>0.2</izz></inertia></inertial>
      <visual name='visual'><geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry><material><ambient>0 0 0 1</ambient></material></visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.4</radius><length>0.3</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name='j_fl' type='revolute'>
      <parent>base_link</parent><child>wheel_fl</child>
      <axis><xyz>0 0 1</xyz><dynamics><damping>500.0</damping><friction>500.0</friction></dynamics></axis>
    </joint>
    <joint name='j_fr' type='revolute'>
      <parent>base_link</parent><child>wheel_fr</child>
      <axis><xyz>0 0 1</xyz><dynamics><damping>500.0</damping><friction>500.0</friction></dynamics></axis>
    </joint>
    <joint name='j_rl' type='revolute'>
      <parent>base_link</parent><child>wheel_rl</child>
      <axis><xyz>0 0 1</xyz><dynamics><damping>500.0</damping><friction>500.0</friction></dynamics></axis>
    </joint>
    <joint name='j_rr' type='revolute'>
      <parent>base_link</parent><child>wheel_rr</child>
      <axis><xyz>0 0 1</xyz><dynamics><damping>500.0</damping><friction>500.0</friction></dynamics></axis>
    </joint>

    <link name='slew_disk'>
      <pose>0 1.4 0.6 0 0 0</pose> 
      <inertial>
        <mass>5.0</mass> 
        <inertia><ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.5</iyy><iyz>0</iyz><izz>0.5</izz></inertia>
      </inertial>
      <visual name='slew_base_vis'>
        <geometry><cylinder><radius>0.6</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.5 0.0 0.0 1</ambient><diffuse>0.6 0.0 0.0 1</diffuse></material>
      </visual>
      <visual name='slew_top_vis'>
        <pose>0 0 0.15 0 0 0</pose>
        <geometry><cylinder><radius>0.5</radius><length>0.1</length></cylinder></geometry>
        <material><ambient>0.5 0.0 0.0 1</ambient><diffuse>0.6 0.0 0.0 1</diffuse></material>
      </visual>
      <collision name='slew_collision'>
        <geometry><cylinder><radius>0.6</radius><length>0.3</length></cylinder></geometry>
      </collision>
    </link>

    <joint name='slew_joint' type='revolute'>
      <parent>base_link</parent>
      <child>slew_disk</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-3.1415</lower><upper>3.1415</upper><effort>30000</effort><velocity>1.0</velocity></limit>
        <dynamics><damping>20.0</damping><friction>15.0</friction></dynamics>
      </axis>
    </joint>

    <link name="camera_link">
    <pose>0.5 1.56 0.75 0 0 0</pose>

    <inertial>
      <mass>0.2</mass>
      <inertia>
        <ixx>0.001</ixx>
        <iyy>0.001</iyy>
        <izz>0.001</izz>
        <ixy>0</ixy>
        <ixz>0</ixz>
        <iyz>0</iyz>
      </inertia>
    </inertial>

    <visual name="camera_visual">
      <geometry>
        <box>
          <size>0.12 0.08 0.08</size>
        </box>
      </geometry>
      <material>
        <ambient>0 0 0 1</ambient>
        <diffuse>0 0 0 1</diffuse>
      </material>
    </visual>

    <collision name="camera_collision">
      <geometry>
        <box>
          <size>0.12 0.08 0.08</size>
        </box>
      </geometry>
    </collision>

    <sensor name="camera" type="camera">
      <pose>0 0 0 0 0 0</pose>

      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.483</horizontal_fov>

        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>

        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>

      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <parent>slew_disk</parent>
    <child>camera_link</child>
  </joint>

    <link name="arm_segment_1">
      <pose>0.865 1.4 0.8 0 1.570796 0</pose>
      <inertial>
        <mass>20.0</mass>
        <inertia><ixx>0.5</ixx><iyy>5.0</iyy><izz>5.0</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="seg1_visual">
        <geometry><cylinder><radius>0.15</radius><length>1.73</length></cylinder></geometry>
        <material><ambient>0.1 0.2 0.5 1</ambient><diffuse>0.2 0.4 0.8 1</diffuse></material>
      </visual>
      <collision name="seg1_collision">
        <geometry><cylinder><radius>0.15</radius><length>1.73</length></cylinder></geometry>
      </collision>
    </link>

    <joint name="shoulder_joint" type="revolute">
      <parent>slew_disk</parent>
      <child>arm_segment_1</child>
      <pose>0 0 -0.865 0 0 0</pose> 
      <axis>
        <xyz>0 1 0</xyz> 
        <limit><lower>-1.57</lower><upper>1.57</upper><effort>5000</effort><velocity>1</velocity></limit>
      </axis>
    </joint>

    <link name="arm_segment_2">
      <pose>2.595 1.4 0.8 0 1.570796 0</pose> 
      <inertial>
        <mass>15.0</mass>
        <inertia><ixx>0.4</ixx><iyy>4.0</iyy><izz>4.0</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="seg2_visual">
        <geometry><cylinder><radius>0.12</radius><length>1.73</length></cylinder></geometry>
        <material><ambient>0.1 0.2 0.5 1</ambient><diffuse>0.2 0.4 0.8 1</diffuse></material>
      </visual>
      <collision name="seg2_collision">
        <geometry><cylinder><radius>0.12</radius><length>1.73</length></cylinder></geometry>
      </collision>
    </link>

    <joint name="elbow_joint" type="revolute">
      <parent>arm_segment_1</parent>
      <child>arm_segment_2</child>
      <pose>0 0 -0.865 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz> 
        <limit><lower>-3.1415</lower><upper>3.1415</upper><effort>2000</effort><velocity>0.5</velocity></limit>
      </axis>
    </joint>

    <link name="front_shovel_block">
      <pose>3.71 1.4 0.8 0 -0.45 0</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>

      <visual name="shovel_back">
        <pose>-0.19 0 0 0 0 0</pose>
        <geometry><box><size>0.02 0.3 0.3</size></box></geometry>
        <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <visual name="shovel_bottom">
        <pose>0.0 0 -0.14 0 0 0</pose>
        <geometry><box><size>0.38 0.3 0.02</size></box></geometry>
        <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <visual name="shovel_side_left">
        <pose>0.0 0.14 0 0 0 0</pose>
        <geometry><box><size>0.4 0.02 0.3</size></box></geometry>
        <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <visual name="shovel_side_right">
        <pose>0.0 -0.14 0 0 0 0</pose>
        <geometry><box><size>0.4 0.02 0.3</size></box></geometry>
        <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
    </link>

    <joint name="shovel_joint" type="fixed">
      <parent>arm_segment_2</parent>
      <child>front_shovel_block</child>
      <pose>-0.25 0 0 0 0 0</pose> 
    </joint>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>slew_joint</joint_name>
      <topic>slew_observer</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>slew_joint</joint_name>
      <topic>slew_ctrl</topic>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>shoulder_joint</joint_name>
      <topic>shoulder_observer</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>shoulder_joint</joint_name>
      <topic>shoulder_ctrl</topic>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>elbow_joint</joint_name>
      <topic>elbow_observer</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>elbow_joint</joint_name>
      <topic>elbow_ctrl</topic>
    </plugin>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
    </plugin>

  </model>
</sdf>