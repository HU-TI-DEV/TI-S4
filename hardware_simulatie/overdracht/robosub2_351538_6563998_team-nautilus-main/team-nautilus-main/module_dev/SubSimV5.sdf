            <link name="firstfinger">
                <pose>0.1921 0.005 -0.0704 0 0 0</pose>
                <visual name="visual">
                    <pose>0.051 0 0 0 0 0</pose>
                    <geometry><box><size>0.102 0.01 0.01</size></box></geometry>
                    <material>
                        <ambient>0.5 0.25 0.25 1</ambient>
                        <diffuse>0.5 0.25 0.25 1</diffuse>
