                <visual name="visual">
                    <pose>0.1175 0 0 0 0 0</pose>
                    <geometry><box><size>0.235 0.01 0.01</size></box></geometry>
                    <material>
                        <ambient>0.2 1 0.2 1</ambient>
                        <diffuse>0.2 1 0.2 1</diffuse>
