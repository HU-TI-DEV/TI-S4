                <collision name="collision">
                    <pose>0.1175 0 0 0 0 0</pose>
                    <geometry><box><size>0.233 0.009 0.009</size></box></geometry>
                </collision>
            </link>

            <link name="wrist">
                <pose>0.027 0 -0.0704 0 0 0</pose>
                <visual name="visual">
                    <pose>0.07755 0 0 0 0 0</pose>
                    <geometry><box><size>0.1551 0.01 0.01</size></box></geometry>
                    <material>
                        <ambient>0.2 0.5 0.5 1</ambient>
