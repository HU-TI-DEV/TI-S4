<?xml version="1.0" ?>
<sdf version="1.7">
    <world name="robosubSimulationV4">

        <gravity>0 0 0</gravity>

        <light name="sun" type="directional">
            <pose>0 0 10 0 0 0</pose>
            <diffuse>1 1 1 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
            <direction>0.1 0.1 -1</direction>
            <cast_shadows>true</cast_shadows>
        </light>

        <model name="robosub">

            <link name="robosubBody">
                <pose>0 0 0.1 0 0 0</pose>
                <visual name="visual">
                    <geometry><box><size>0.4 0.2 0.2</size></box></geometry>
                    <material>
                        <ambient>0.5 0.5 0.5 1</ambient>
                        <diffuse>0.5 0.5 0.5 1</diffuse>
                    </material>
                </visual>
                <collision name="collision">
                    <geometry><box><size>0.49 0.29 0.19</size></box></geometry>
                </collision>
            </link>

            <link name="base">
                <pose>0 0 -0.0206 0 0 0</pose>
                <visual name="visual">
                    <geometry><box><size>0.01 0.01 0.0412</size></box></geometry>
                    <material>
                        <ambient>1 0.2 0.2 1</ambient>
                        <diffuse>1 0.2 0.2 1</diffuse>
                    </material>
                </visual>
                <collision name="collision">
                    <geometry><box><size>0.01 0.01 0.0412</size></box></geometry>
                </collision>
            </link>

            <link name="upperarm">
                <pose>0 0 -0.0412 0 0 0</pose>
