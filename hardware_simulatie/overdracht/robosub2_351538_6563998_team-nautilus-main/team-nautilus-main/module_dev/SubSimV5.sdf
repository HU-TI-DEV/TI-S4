                    <pose>0.051 0 0 0 0 0</pose>
                    <geometry><box><size>0.102 0.009 0.009</size></box></geometry>
                </collision>
            </link>

            <!-- camera -->
            <link name="camera_link">
                <pose relative_to="robosubBody">0.25 0 0 0 0.78 0</pose>
                <visual name="camera_visual">
                    <geometry>
                        <box>
                            <size>0.05 0.05 0.05</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0 0 1 1</ambient>
                    </material>
                </visual>

                <sensor name="rgbd_camera" type="rgbd_camera">
                    <pose relative_to="camera_link">0 0 0 0 0 0</pose>
                    <always_on>true</always_on>
                    <update_rate>30</update_rate>
                    <visualize>true</visualize>

                    <camera>
                        <horizontal_fov>1.047</horizontal_fov>
                        <image>
                            <width>640</width>
                            <height>480</height>
                            <format>R8G8B8</format>
                        </image>
                        <clip>
                            <near>0.1</near>
                            <far>100</far>
                        </clip>
                    </camera>

                    <topic>/camera</topic>
                </sensor>
            </link>

            <joint name="cameraBToSub" type="fixed">
                <parent>robosubBody</parent>
                <child>camera_link</child>
            </joint>

            <joint name="fixedToWorld" type="fixed">
                <parent>world</parent>
                <child>robosubBody</child>
            </joint>

            <joint name="subToBase" type="revolute">
                <parent>robosubBody</parent>
                <child>base</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit>
                        <lower>-0.7854</lower>
                        <upper>0.7854</upper>
                        <effort>1000000</effort>
                    </limit>
                </axis>
            </joint>

            <joint name="baseToUpperarm" type="revolute">
                <parent>base</parent>
                <child>upperarm</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit><lower>-1.8307</lower><upper>0</upper><effort>1000000</effort></limit>
                </axis>
            </joint>

            <joint name="upperarmToForearm" type="revolute">
                <parent>upperarm</parent>
                <child>forearm</child>
                <axis>
                    <xyz>0 -1 0</xyz>
                    <limit><lower>-1.6493</lower><upper>0</upper><effort>1000000</effort></limit>
                </axis>
            </joint>

            <joint name="forearmToWrist" type="revolute">
                <parent>forearm</parent>
                <child>wrist</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit><lower>-0.3491</lower><upper>1.7523</upper><effort>1000000</effort></limit>
                </axis>
            </joint>

            <joint name="wristToHand" type="revolute">
                <parent>wrist</parent>
                <child>hand</child>
                <axis>
                    <xyz>1 0 0</xyz>
                    <limit><lower>0</lower><upper>4.7124</upper><effort>1000000</effort></limit>
                </axis>
            </joint>

            <joint name="handToFirstfinger" type="revolute">
                <parent>hand</parent>
                <child>firstfinger</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit><lower>0</lower><upper>0.7854</upper><effort>1000000</effort></limit>
                </axis>
            </joint>

            <joint name="handToSecondfinger" type="revolute">
                <parent>hand</parent>
                <child>secondfinger</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit><lower>-0.7854</lower><upper>0</upper><effort>1000000</effort></limit>
                </axis>
            </joint>

            <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>

            <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
                <joint_name>subToBase</joint_name>
                <topic>/subToBaseTopic</topic>
                <initial_position>0.0</initial_position>
            </plugin>

            <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
                <joint_name>baseToUpperarm</joint_name>
                <topic>/baseToUpperarmTopic</topic>
                <initial_position>0.0</initial_position>
            </plugin>

            <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
                <joint_name>upperarmToForearm</joint_name>
                <topic>/upperarmToForearmTopic</topic>
                <initial_position>0.0</initial_position>
            </plugin>

            <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
                <joint_name>forearmToWrist</joint_name>
                <topic>/forearmToWristTopic</topic>
                <initial_position>0.0</initial_position>
