                    <pose>-0.104 0 0 0 0 0</pose>
                    <geometry><box><size>0.208 0.01 0.01</size></box></geometry>
                    <material>
                        <ambient>0.2 0.2 1 1</ambient>
                        <diffuse>0.2 0.2 1 1</diffuse>
                    </material>
                </visual>
                <collision name="collision1">
                    <pose>-0.104 0 0 0 0 0</pose>
                    <geometry><box><size>0.206 0.009 0.009</size></box></geometry>
                </collision>
                <visual name="visual2">
                    <pose>-0.208 0 -0.0146 0 0 0</pose>
                    <geometry><box><size>0.01 0.01 0.0292</size></box></geometry>
                    <material>
                        <ambient>0.2 0.2 1 1</ambient>
                        <diffuse>0.2 0.2 1 1</diffuse>
                    </material>
                </visual>
                <collision name="collision2">
                    <pose>-0.208 0 -0.0146 0 0 0</pose>
                    <geometry><box><size>0.009 0.009 0.028</size></box></geometry>
                </collision>
            </link>

            <link name="forearm">
