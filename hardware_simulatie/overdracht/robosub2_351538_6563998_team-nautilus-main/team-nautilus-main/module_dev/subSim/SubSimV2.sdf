      <!-- joint plugins -->
      <!-- jointcontroller plugins -->
      <plugin
        filename="gz-sim-joint-controller-system"
        name="gz::sim::systems::JointController">
        <joint_name>subToBase</joint_name>
        <initial_velocity>0</initial_velocity>
        <topic>/subToBaseTopic</topic>
      </plugin>

      <plugin
        filename="gz-sim-joint-controller-system"
        name="gz::sim::systems::JointController">
        <joint_name>baseToUpperarm</joint_name>
