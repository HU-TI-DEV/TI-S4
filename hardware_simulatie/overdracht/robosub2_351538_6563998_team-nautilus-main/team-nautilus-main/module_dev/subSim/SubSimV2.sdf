        <link_name>secondfinger</link_name>
        <linear_damping>-1 -1 -1 -0.1 -0.1 -0.1</linear_damping>
        <quadratic_damping>-0.5 -0.5 -0.5 -0.05 -0.05 -0.05</quadratic_damping>
      </plugin>

      <!-- Joints -->

      <!-- join body to the world so it is not  -->
      <joint name="fixedToWorld" type="fixed">
        <parent>world</parent>
        <child>robosub_body</child>
      </joint>
      
      <joint name="subToBase" type="revolute">
        <parent>robosub_body</parent>
        <child>base</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-2.3562</lower>
            <upper>2.3562</upper>
            <effort>10</effort>
            <velocity>1.0</velocity>
          </limit>
        </axis>
      </joint>

   <joint name="baseToUpperarm" type="revolute">
     <parent>base</parent>
     <child>upperarm</child>
     <pose>0 0 0 0 0.7 0</pose>
     <axis>
       <xyz>0 -1 0</xyz>
       <limit>
         <lower>0</lower>
         <upper>1.5708</upper>
         <effort>10</effort>
         <velocity>1.0</velocity>
       </limit>
     </axis>
   </joint>

      <joint name="upperarmToForearm" type="revolute">
        <parent>upperarm</parent>
        <child>forearm</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>0.1396</lower>
            <upper>3.0014</upper>
            <effort>10</effort>
            <velocity>1.0</velocity>
          </limit>
        </axis>
      </joint>

      <joint name="forearmToWrist" type="revolute">
        <parent>forearm</parent>
        <child>wrist</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-0.3491</lower>
            <upper>1.7279</upper>
            <effort>10</effort>
            <velocity>1.0</velocity>
          </limit>
        </axis>
      </joint>

      <joint name="wristToHand" type="revolute">
        <parent>wrist</parent>
        <child>hand</child>
        <axis>
          <xyz>1 0 0</xyz>
          <limit>
            <lower>0</lower>
            <upper>1.5708</upper>
            <effort>10</effort>
            <velocity>1.0</velocity>
          </limit>
        </axis>
      </joint>

      <joint name="handToFirstfinger" type="revolute">
        <parent>hand</parent>
        <child>firstfinger</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>0</lower>
            <upper>0.7854</upper>
            <effort>10</effort>
            <velocity>1.0</velocity>
          </limit>
        </axis>
      </joint>

      <joint name="handToSecondfinger" type="revolute">
        <parent>hand</parent>
        <child>secondfinger</child>
        <axis>
          <xyz>0 0 -1</xyz>
          <limit>
            <lower>0</lower>
            <upper>0.7854</upper>
            <effort>10</effort>
            <velocity>1.0</velocity>
          </limit>
        </axis>
      </joint>

    </model>
  </world>
</sdf>
