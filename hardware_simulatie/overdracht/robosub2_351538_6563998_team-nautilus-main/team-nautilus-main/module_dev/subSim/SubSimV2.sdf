<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="robosub_simulation_V2">

    <!-- Lighting -->
    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <direction>0.1 0.1 -1</direction>
      <cast_shadows>true</cast_shadows>
    </light>

    <!-- buoyancy plugin -->
    <plugin filename="gz-sim-buoyancy-system"
            name="gz::sim::systems::Buoyancy">
      <uniform_fluid_density>1000</uniform_fluid_density>
    </plugin>

    <!-- seafloor at z= -10-->
    <model name="seafloor">
      <static>true</static>
      <pose>0 0 -10 0 0 0</pose>
      <link name="link">
        <collision name="seafloor_collision">
          <geometry>
            <plane><normal>0 0 1</normal></plane>
          </geometry>
        </collision>
        <visual name="seafloor_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <material>
            <diffuse>0.75 0.70 0.45 1</diffuse>
  	        <ambient>0.75 0.70 0.45 1</ambient>
          </material>
        </visual>
      </link>
    </model>

    <!-- sub model -->
    <model name="robosub">
      <!-- static robosub body -->
      <link name="robosub_body">

        <pose>0 0 0 0 0 0</pose>

        <visual name="robosub_body_visual">
          <pose>0 0 0.03 0 0 0</pose>
          <geometry>
            <box>
              <size>0.8 0.4 0.2</size>
            </box>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1.0</ambient>
            <diffuse>0.5 0.5 0.5 1.0</diffuse>
          </material>
        </visual>

        <collision name="robosub_body_collision">
          <pose>0 0 0.03 0 0 0</pose>
          <geometry>
            <box>
              <size>0.8 0.4 0.2</size>
            </box>
          </geometry>
        </collision>

      </link>
      
      <!-- start of the robot arm model -->
      <!-- Base -->
      <link name="base">
        <pose>0 0 -0.06 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.001</iyy><iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>

        <visual name="base_visual_0">
          <pose>0 0 -0.02 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.030</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1.0 0.2 0.2 1.0</ambient>
            <diffuse>1.0 0.2 0.2 1.0</diffuse>
          </material>
        </visual>
        <collision name="base_collision_0">
          <pose>0 0 -0.02 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.030</length>
            </cylinder>
          </geometry>
        </collision>

        <visual name="base_visual_1">
          <pose>0 0 -0.045 1.5708 0 0</pose>
          <geometry>
            <box>
              <size>0.05 0.03 0.03</size>
            </box>
          </geometry>
          <material>
            <ambient>1.0 0.2 0.2 1.0</ambient>
            <diffuse>1.0 0.2 0.2 1.0</diffuse>
