      <joint name="subToBase" type="revolute">
        <parent>robosubBody</parent>
        <child>base</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-0.7854</lower>
            <upper>0.7854</upper>
            <effort>1000000</effort>
          </limit>
        </axis>
      </joint>

      <joint name="baseToUpperarm" type="revolute">
        <parent>base</parent>
        <child>upperarm</child>
        <axis>
